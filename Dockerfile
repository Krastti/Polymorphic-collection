# =============================================================================
# Dockerfile для Matrix Calculator Web Service
# Базовый образ: Ubuntu 22.04  |  сборка в стандартный build/
# =============================================================================

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# =============================================================================
# 1. Системные зависимости
# =============================================================================
RUN apt-get update && apt-get install -y \
    gcc \
    make \
    python3 \
    python3-pip \
    python3-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir cmake==3.31.6

# =============================================================================
# 2. Python-зависимости сервиса
# =============================================================================
RUN pip3 install --no-cache-dir \
    fastapi==0.115.0 \
    uvicorn[standard]==0.30.0 \
    pydantic==2.7.0

# =============================================================================
# 3. Рабочая директория проекта
# =============================================================================
WORKDIR /app

# =============================================================================
# 4. Копируем исходники
#
#    Ожидаемая структура проекта рядом с Dockerfile:
#
#    project/
#    ├── Dockerfile
#    ├── CMakeLists.txt
#    ├── src/
#    ├── web/              ← папка с фронтендом (index.html, app.js, style.css)
#    └── server/
# =============================================================================
COPY src/            /app/src/
COPY CMakeLists.txt  /app/CMakeLists.txt

# Копируем реальный фронтенд — main.py ищет web/ на уровень выше server/
COPY web/            /app/web/

# =============================================================================
# 5. Сборка .so
# =============================================================================
RUN cmake -S /app -B /app/build \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTS=OFF \
    && cmake --build /app/build --target matrix_lib -- -j"$(nproc)"

ENV LD_LIBRARY_PATH="/app/build"

# =============================================================================
# 6. Python-сервер
# =============================================================================
COPY server/ /app/server/

WORKDIR /app/server

EXPOSE 8000

# =============================================================================
# 7. Healthcheck
# =============================================================================
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# =============================================================================
# 8. Запуск — без open_browser, браузер открываешь сам на хосте
# =============================================================================
CMD ["python3", "-m", "uvicorn", "main:app", \
     "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]
